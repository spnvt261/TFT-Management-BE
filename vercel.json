{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix apps/api --include=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "apps/api/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "apps/api/db/migrations/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
